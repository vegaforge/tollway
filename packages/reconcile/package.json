{
  "name": "@tollway/reconcile",
  "version": "0.0.1",
  "description": "Reconciles off-chain channel commitments against on-chain settlement and flags drift",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vegaforge/tollway.git",
    "directory": "packages/reconcile"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tollway/core": "workspace:*"
  },
  "devDependencies": {
    "fast-check": "^3.23.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
